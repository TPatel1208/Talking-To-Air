# =========================
# Earthdata / NASA Auth
# =========================
EARTHDATA_USERNAME=your_earthdata_username
EARTHDATA_PASSWORD=your_earthdata_password

EDL_USERNAME=your_edl_username
EDL_PASSWORD=your_edl_password

# =========================
# Database
# =========================
DATABASE_URL=postgresql://postgres:yourpassword@db:5432/talking_to_air_memory

DB_HOST=db
DB_PORT=5432
DB_NAME=talking_to_air_memory
DB_USER=postgres
DB_PASSWORD=your_db_password

# =========================
# API Keys
# =========================
GOOGLE_API_KEY=your_google_api_key
GROQ_API_KEY=your_groq_api_key

AQS_API_KEY=your_aqs_api_key
AQS_API_EMAIL=your_email@example.com

# =========================
# Models
# =========================
SATELLITE_AGENT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROUND_AGENT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
LLM_MODEL=gemma-4-26b-a4b-it

# =========================
# Frontend / CORS
# =========================
CORS_ORIGINS=http://localhost:5173,http://localhost

# =========================
# LangSmith / LangChain
# =========================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=talking_to_air_monitoring


# =========================
# Data Fetch Tuning
# =========================

# Lock the fetch strategy across all collections.
# auto    — (default) smart routing: Harmony for LARC_CLOUD w/ var-subsetting,
#           OPeNDAP CE for GES_DISC, S3 fallback inside us-west-2 only
# harmony — always use Harmony (fastest for tight bounding boxes anywhere)
# opendap — always use OPeNDAP constraint expressions (GES_DISC only)
# s3      — always try S3 direct (requires S3_FORCE_FETCH=1 outside us-west-2)
DATA_FETCH_MODE=auto

# Set to 1 to bypass the us-west-2 region check and always attempt S3 fetches.
# Only useful when you have verified acceptable S3 latency from your location.
S3_FORCE_FETCH=0
