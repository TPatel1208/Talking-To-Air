DB_USER=postgres
DB_PASSWORD=yourpassword

# ── Google Gemini ─────────────────────────────────────────────
GOOGLE_API_KEY=your-google-api-key

# ── EPA AQS ───────────────────────────────────────────────────
AQS_API_KEY=your-aqs-api-key
