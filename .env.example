# ── NASA Earthdata ────────────────────────────────────────────
EARTHDATA_USERNAME=your-earthdata-username
EARTHDATA_PASSWORD=your-earthdata-password

EDL_USERNAME=your-earthdata-username
EDL_PASSWORD=your-earthdata-password

# ── Database ──────────────────────────────────────────────────
