# =========================
# Earthdata / NASA Auth
# =========================
EARTHDATA_USERNAME=your_earthdata_username
EARTHDATA_PASSWORD=your_earthdata_password

EDL_USERNAME=your_edl_username
EDL_PASSWORD=your_edl_password

# =========================
# Database
# =========================
DATABASE_URL=postgresql://postgres:yourpassword@db:5432/talking_to_air_memory

DB_HOST=db
DB_PORT=5432
DB_NAME=talking_to_air_memory
DB_USER=postgres
DB_PASSWORD=your_db_password

# =========================
# API Keys
# =========================
GOOGLE_API_KEY=your_google_api_key
GROQ_API_KEY=your_groq_api_key

AQS_API_KEY=your_aqs_api_key
AQS_API_EMAIL=your_email@example.com

# =========================
# Models
# =========================
SATELLITE_AGENT_MODEL = meta-llama/llama-4-scout-17b-16e-instruct
GROUND_AGENT_MODEL =meta-llama/llama-4-scout-17b-16e-instruct
LLM_MODEL =openai/gpt-oss-120b

# =========================
# Frontend / CORS
# =========================
CORS_ORIGINS=http://localhost:5173,http://localhost

# =========================
# Logging / Observability
# =========================
LOG_LEVEL=INFO
LOG_FORMAT=text
LONG_REQUEST_SECONDS=30

# =========================
# Authentication
# =========================
JWT_SECRET_KEY=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# =========================
# LangSmith / LangChain
# =========================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=talking_to_air_monitoring


# =========================
# Data Fetch Tuning
# =========================

# Lock the fetch strategy across all collections.
# auto    — (default) smart routing: Harmony for LARC_CLOUD w/ var-subsetting,
#           OPeNDAP CE for GES_DISC, S3 fallback inside us-west-2 only
# harmony — always use Harmony (fastest for tight bounding boxes anywhere)
# opendap — always use OPeNDAP constraint expressions (GES_DISC only)
# s3      — always try S3 direct (requires S3_FORCE_FETCH=1 outside us-west-2)
DATA_FETCH_MODE=auto

# Set to 1 to bypass the us-west-2 region check and always attempt S3 fetches.
# Only useful when you have verified acceptable S3 latency from your location.
S3_FORCE_FETCH=0

# Safety cap for satellite provider result counts.
SATELLITE_MAX_RESULTS_CAP=20

# Maximum seconds to wait for NASA Harmony job processing before timing out.
HARMONY_PROCESSING_TIMEOUT_SECONDS=600

# =========================
# earthdata-retrieval MCP
# =========================
# Shared-network URL of the harmony-retrieval-mcp stack's HTTP endpoint
# (that stack's compose service is named `mcp`, joined on the shared
# `earthdata_net` external network — see docker-compose.yml).
EARTHDATA_MCP_URL=http://mcp:8765/mcp

# Bearer token required by the MCP's HTTP transport when it has one
# configured (EARTHDATA_MCP_TOKEN in that repo's .env). Must match.
EARTHDATA_MCP_TOKEN=your_earthdata_mcp_token

# safe_retrieve gate: estimates at/below this proceed automatically.
RETRIEVAL_SOFT_CAP_BYTES=2147483648

# safe_retrieve gate: estimates above this are refused outright, with
# guidance to narrow the request. Between the soft and hard cap, the
# retrieval pauses for in-chat confirmation.
RETRIEVAL_HARD_CAP_BYTES=10737418240

# await_retrieval polling backoff bounds (seconds) while waiting for a
# retrieval job to reach a terminal state.
AWAIT_RETRIEVAL_POLL_MIN_SECONDS=2
AWAIT_RETRIEVAL_POLL_MAX_SECONDS=15

# Maximum seconds await_retrieval will poll before giving up on a job.
AWAIT_RETRIEVAL_TIMEOUT_SECONDS=900
